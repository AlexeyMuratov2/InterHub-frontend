# Скопируйте в .env.production локально или задайте те же значения в GitHub Actions → Variables.
# Секреты бэкенда сюда не кладутся — только публичные VITE_* (попадают в браузерный бандл).
#
# CI/CD (ветка test_deploy_miniapp):
#   Variable VITE_MINIAPP_API_BASE_URL = значение ниже (или оставьте только VITE_API_BASE_URL как fallback)
#   Secret FRONTEND_MINIAPP_DIST_PATH = каталог на сервере, совпадающий с root в Caddy для miniapp

# Origin API без хвоста /api (в коде уже есть префикс /api/...).
# Если Caddy на miniapp.interhub.online проксирует /api на тот же бэкенд:
VITE_API_BASE_URL=https://miniapp.interhub.online

# Если API остаётся на основном домене (учтите CORS и cookie SameSite на бэкенде):
# VITE_API_BASE_URL=https://interhub.online
