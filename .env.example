# Copy to .env for local dev or .env.production for CI build.
# Do not put secrets here; VITE_* variables are public in browser bundle.

# Public API origin only — do not add /api (request paths already include /api/...).
# Leave empty for local dev: requests go to same origin and Vite proxies /api to the backend.
VITE_API_BASE_URL=https://your-domain.com